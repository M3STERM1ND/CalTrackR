# Which vision provider analyzeFood() uses. Defaults to "claude".
# Options: mock | openai | gemini | claude
NEXT_PUBLIC_AI_PROVIDER=claude

# Anthropic API key — required for the claude provider (server-side only, never exposed to the browser)
ANTHROPIC_API_KEY=your-key-here

# Other provider keys (only needed if switching providers above)
# OPENAI_API_KEY=
# GEMINI_API_KEY=
